{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    ":automergePatch",
    ":automergeBranch"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    }
  ],
  "labels": ["dependencies"],
  "assignees": ["mirogta"]
}
